# ===== ASCENDR environment variables =====
# Copy this file to .env.local and fill in your NEW Supabase project values.
# These are SEPARATE from MentorBay — create a brand-new Supabase project for ASCENDR.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-NEW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key — NEVER expose to the client. Used only in webhooks/jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Add later as features come online (per the Master PRD) ---
# OPENAI_API_KEY=                # AI Coach + Mentor Clone (RAG)
# MPESA_CONSUMER_KEY=            # Payments (Kenya)
# MPESA_CONSUMER_SECRET=
# PAYSTACK_SECRET_KEY=          # Cards / international
# LIVEKIT_API_KEY=             # Live sessions video
# LIVEKIT_API_SECRET=
# RESEND_API_KEY=              # Transactional email / digests
